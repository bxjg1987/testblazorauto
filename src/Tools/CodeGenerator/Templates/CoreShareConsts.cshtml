@using CodeGenerator
@using RazorLight
@inherits TemplatePage<ExecuteContext>
@{
    DisableEncoding = true;//禁止html编码，因为我们是做代码生成器
}
@foreach (var field in Model.Model.Fields)
{
    if (field.Length>0)
    {
        @:public const int @(Model.Model.Name)@(field.Name)MaxLength = @(field.Length);
    }
}