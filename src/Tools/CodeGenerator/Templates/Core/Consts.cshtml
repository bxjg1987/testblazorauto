@using CodeGenerator
@using RazorLight
@using BXJG.Common;
@using BXJG.Common.Extensions;
@inherits TemplatePage<ExecuteContext>
@{
    DisableEncoding = true;//禁止html编码，因为我们是做代码生成器
}
namespace @Model.Model.CoreShareNamespace
{
    /// <summary>
    /// @(Model.Model.DisplayName)Core share 常量
    ///</summary>
    public class @Model.Model.CoreShareConstName
    {
@foreach (var field in Model.Model.StringFields){
    if (field.Length>0){<text>
        /// <summary>
        /// @(field.DisplayName) 长度
        ///</summary>
        public const int @(field.MaxLength) = @(field.Length);
    </text>}
}
    }
}