@using CodeGenerator
@using RazorLight
@using BXJG.Common;
@using BXJG.Common.Extensions;
@inherits TemplatePage<ExecuteContext>
@{
    DisableEncoding = true;//禁止html编码，因为我们是做代码生成器
}
using Abp.Domain.Entities;
using Abp.Domain.Entities.Auditing;
using System;
using System.ComponentModel.DataAnnotations.Schema;
@if (Model.Model.IsTree)
{
@:using BXJG.Utils.GeneralTree;    
}

namespace @Model.Model.CoreNamespace
{
    /// <summary>
    /// @Model.Model.DisplayName
    ///</summary>
    public class @Model.Model.EntityName : @(Model.Model.IsTree?$"GeneralTreeEntity<{Model.Model.EntityName}>":( Model.Model.PrimaryField.CSharpType=="int"?"FullAuditedEntity": $"FullAuditedEntity<{Model.Model.PrimaryField.CSharpType}>" ))
    {
@foreach (var field in Model.Model.NormalFields)
{
        @:/// <summary>
        @:/// @field.DisplayName
        @:///</summary>
        @:public @field.CSharpType @field.Name { get; set; }
}
    }
}