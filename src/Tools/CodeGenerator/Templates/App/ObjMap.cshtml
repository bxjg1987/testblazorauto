@using CodeGenerator
@using RazorLight
@using BXJG.Common;
@
@inherits TemplatePage<ExecuteContext>
@{
    DisableEncoding = true;//禁止html编码，因为我们是做代码生成器
}
using AutoMapper;
using @(Model.Model.ApplicationShareNamespace);
using @(Model.Model.CoreNamespace);

namespace @(Model.Model.ApplicationNamespace)
{
    public partial class AutoMapperProfile : Profile
    {
        public AutoMapperProfile()
        {
            CreateMap<@(Model.Model.EntityName), @(Model.Model.DtoName)>();
            CreateMap<@(Model.Model.EditDtoName), @(Model.Model.EntityName)>();
            CreateMap<@(Model.Model.CreateDtoName), @(Model.Model.EntityName)>();
        }
    }
}