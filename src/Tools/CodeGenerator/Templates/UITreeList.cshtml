@using CodeGenerator
@using RazorLight
@using BXJG.Common;
@using BXJG.Common.Extensions;
@inherits TemplatePage<ExecuteContext>
@{
    DisableEncoding = true;//禁止html编码，因为我们是做代码生成器
}
@("@page") "/@(Model.Model.Name)"
@@using BXJG.Utils.Application.Share.GeneralTree
@@using @(Model.Model.ApplicationShareNamespace);

@@attribute [ReuseTabsPage(Title = "@Model.Model.DisplayName")]
@@attribute [Authorize(@Model.Model.PermissionNameGetConst)]
@@inherits TreeListBaseComponent<@Model.Model.DtoName, @Model.Model.ConditionName>

<Flex Gap="small" Vertical Justify="space-between">
     <Flex Justify="space-between">
         @@* 左侧 *@@
         <Flex Gap="small">
            @@if (createIsGranted)
            {
                <Button Type="@@ButtonType.Primary" Icon="@@IconType.Outline.Plus" OnClick="BtnCreateClick">新增</Button>
            }
            @@if(deleteIsGranted)
            {
                <Popconfirm Title="将删除已经的项及其所有子项，确定删除吗?"
                            OnConfirm="BtnDeleteClick">
                    <Button Type="@@ButtonType.Default" Icon="@@IconType.Outline.Clear" Danger Loading=isDeleting Disabled=ShouldDisableDelete>删除</Button>
                </Popconfirm>
            }
        </Flex>
        @@* 右侧 *@@
        <Flex Gap="small">
            <div style="width:15rem;">
                <Search Placeholder="请输入关键字..." @@bind-Value=Keywords OnChange=BtnSearchClick AllowClear ClassicSearchIcon Disabled=IsLoading />
            </div>
            <Tooltip Title="清空条件">
                <Button Type="@@ButtonType.Default" Icon="@@IconType.Outline.Clear" OnClick="BtnClearFilterClick" Disabled=IsLoading></Button>
            </Tooltip>
            <Tooltip Title="刷新">
                <Button Type="@@ButtonType.Default" Icon="@@IconType.Outline.Reload" OnClick="BtnRefreshClick" Disabled=IsLoading></Button>
            </Tooltip>
        </Flex>
    </Flex>

    @@* 不能定义key，不然无法刷新子节点 *@@
    <Table @@ref="table"
           TreeChildren=GetTreeChildren
           TItem="@Model.Model.DtoName"
           Total="TotalCount"
           @@bind-SelectedRows="SelectedItems"
           OnChange="OnQuery"
           DataSource="Items"
           Loading="IsLoading"
           HidePagination=true
           RowClassName="@@(r=>r.RowIndex%2==0?"even":"odd")"
           RemoteDataSource="true"
           OnRow="Row"
           Size="TableSize.Small"
           Bordered="true"
           ScrollY="76vh">
        <Selection Key="@@(context.Id.ToString())" />
@foreach (var field in Model.Model.NormalFields){
    @if(field.CSharpType=="bool"){
        <PropertyColumn Property="c=>c.@(field.Name)" ShowSorterTooltip="false" Width="5rem" @(field.FixedLeft==true?@"Fixed=""left""":(field.FixedLeft==false?@"Fixed=""right""":"")) Align=ColumnAlign.Center>
            <Switch @@bind-Value="@@context.IsSysDefine" Size="@@InputSize.Small" Disabled="true"></Switch>
        </PropertyColumn>
    }else{
        <PropertyColumn Property="c=>c.@(field.Name)" @(field.IsSort?"Sortable":"") ShowSorterTooltip="false" @(field.Width.IsNullOrWhiteSpaceBXJG()?"":@$"Width=""{field.Width}""") @(field.FixedLeft==true?@"Fixed=""left""":(field.FixedLeft==false?@"Fixed=""right""":"")) @(field.Position==true?"":(field.FixedLeft==false?@"Align=ColumnAlign.Right":"Align=ColumnAlign.Center"))/>        
    }
}
        <ActionColumn Title="操作" Width="240">
            <ButtonGroup Size="@@ButtonSize.Small">
                    <Button Size="@@ButtonSize.Small" Type="@@ButtonType.Primary" OnClick="x=>BtnItemDetailClick(context)">详情</Button>
                @@if (createIsGranted)
                {
                    <Button Size="@@ButtonSize.Small" OnClick="x=>BtnAddSubClick(context.Id)">添加子节点</Button>
                }
                @@if (updateIsGranted)
                {
                    <Button Size="@@ButtonSize.Small" OnClick="x=>BtnItemEditClick(context)">修改</Button>
                }
                @@if (deleteIsGranted)
                {
                    <Popconfirm Title="将删除此项及其所有子项，确定删除吗?" OnConfirm="()=>BtnDeleteItemClick(context)">
                        <Button Size="@@ButtonSize.Small" Danger="true" Loading=@@context.ExtensionData.IsDeleting>删除</Button>
                    </Popconfirm>
                }
            </ButtonGroup>
        </ActionColumn>
    </Table>

</Flex>

@@{
    RenderFragment renderFragment =@@<Template>
        <SectionOutlet SectionName=@@($"{GetHashCode()}-create-btns") />
        <Button OnClick="BtnCloseCreateClick">关闭</Button>
    </Template>;
}
    <Modal DestroyOnClose="true" Footer="renderFragment" @@bind-Visible="isShowCreateDialog" Draggable="true" Width=@@("40vw")>
    <TitleTemplate>
        <Icon Type="plus" Theme="outline" />
        新增@@(FuncName)
    </TitleTemplate>
    <ChildContent>
        <SectionOutlet SectionName="@@($"{GetHashCode()}-create-body" )" />
        <Create OnAddEnd="AddEnd" ParentId="parentId"  Master="GetHashCode()"/>
    </ChildContent>
</Modal>

@@{
    RenderFragment renderFragment1 =@@<Template>
        <SectionOutlet SectionName=@@($"{GetHashCode()}-detail-update-btns") />
        <Button OnClick="BtnDetailUpdateCloseClick">关闭</Button>
    </Template>;
}
<Modal DestroyOnClose="true" Footer="renderFragment1" @@bind-Visible="isShowDetailUpdateDialog" Draggable="true" Width=@@("40vw")>
    <TitleTemplate>
        <SectionOutlet SectionName=@@($"{GetHashCode()}-detail-update-title") />
    </TitleTemplate>
    <ChildContent>
        <SectionOutlet SectionName=@@($"{GetHashCode()}-detail-update-body") />
        <DetailUpdate Id="detailUpdateId" IsEdit="isEdit" OnDeleted="DetailDeleted" OnUpdated="DetailUpdated" Master="GetHashCode()"/>
    </ChildContent>
</Modal>