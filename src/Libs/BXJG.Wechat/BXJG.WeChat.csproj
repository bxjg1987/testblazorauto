<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <AssemblyName>BXJG.WeChat</AssemblyName>
    <Authors>变形精怪</Authors>
    <RepositoryUrl>https://gitee.com/bxjg1987_admin/abp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Description>微信小程序登录、支付。
视频教程：https://www.bilibili.com/video/BV1Uk4y1d7Be/
源码：https://gitee.com/bxjg1987_admin/abp</Description>
    <Version>1.2.10</Version>
    <PackageProjectUrl>https://gitee.com/bxjg1987_admin/abp</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageId>BXJG.WeChat</PackageId>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
