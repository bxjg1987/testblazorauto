@inherits AbpMudBaseComponent
<MudDialog>
    <DialogContent>
        <DynamicComponent Type="CreateComponentType" @ref="createComponent"></DynamicComponent>
    </DialogContent>
    <DialogActions>
        @*新增时，好像真的没必要允许自定义按钮，修改时貌似需要*@
        <MudButton OnClick="SaveClick">保存</MudButton>
        <MudButton OnClick="()=>MudDialog.Cancel()">关闭</MudButton>
    </DialogActions>
</MudDialog>