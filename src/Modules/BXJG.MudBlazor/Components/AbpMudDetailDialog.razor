@inherits AbpMudBaseComponent

<DynamicComponent Type="DetailComponentType" @ref="dynamicComponent"></DynamicComponent>

<MudDialog>
    <DialogContent>
        @detail?.Body
    </DialogContent>
    <DialogActions>
        @detail?.Buttons
        <MudButton StartIcon="@Icons.Material.Outlined.ArrowBack" Variant="Variant.Filled" Color="Color.Default" OnClick="()=>MudDialog.Cancel()">关闭</MudButton>
    </DialogActions>
</MudDialog>