<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <RootNamespace>BXJG.WorkOrder</RootNamespace>
    <Version>1.2.8</Version>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <LangVersion>default</LangVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <LangVersion>default</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="DefaultClsManager.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Localization\SourceFiles\BXJGWorkOrder-en.xml" />
    <None Remove="Localization\SourceFiles\BXJGWorkOrder-zh-Hans.xml" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Localization\SourceFiles\BXJGWorkOrder-en.xml" />
    <EmbeddedResource Include="Localization\SourceFiles\BXJGWorkOrder-zh-Hans.xml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Abp" Version="8.2.0" />
    <PackageReference Include="BXJG.Utils" Version="1.2.19" />
    <PackageReference Include="Yitter.IdGenerator" Version="1.*" />
  </ItemGroup>

</Project>
