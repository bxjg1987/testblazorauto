<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8;net9</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<VersionPrefix>1.3.97</VersionPrefix>
		<LangVersion>latest</LangVersion>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
	</PropertyGroup>
	
	<ItemGroup>
		<Compile Remove="Concurrency\MapperExtension.cs" />
		<Compile Remove="Files\FileResult.cs" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net9'">
		<PackageReference Include="Abp" Version="10.*" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net8'">
		<PackageReference Include="Abp" Version="9.*" />
	</ItemGroup>
	<ItemGroup>
		<Folder Include="GeneralTree\" />
	</ItemGroup>

</Project>
