<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9;net10.0</TargetFrameworks>
	  <VersionPrefix>1.3.119</VersionPrefix>
	  <LangVersion>latest</LangVersion>
	  <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

 

  <ItemGroup>
    <Compile Remove="authorization\**" />
    <Compile Remove="Events\**" />
    <Compile Remove="GeneralTree\**" />
    <Compile Remove="SessionExt\**" />
    <EmbeddedResource Remove="authorization\**" />
    <EmbeddedResource Remove="Events\**" />
    <EmbeddedResource Remove="GeneralTree\**" />
    <EmbeddedResource Remove="SessionExt\**" />
    <None Remove="authorization\**" />
    <None Remove="Events\**" />
    <None Remove="GeneralTree\**" />
    <None Remove="SessionExt\**" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Abp.AspNetCore" Version="10.*" />
    <PackageReference Include="Abp.AspNetCore.SignalR" Version="10.*" />
    <PackageReference Include="AsyncKeyedLock" Version="7.1.7" />
  
  </ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' != 'net9'">
		<PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.*" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9'">
		<PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.10" />
	</ItemGroup>
	
	
  <ItemGroup>
    <ProjectReference Include="..\..\libs\BXJG.Common.Web\BXJG.Common.Web.csproj" />
    <ProjectReference Include="..\BXJG.Utils.Application\BXJG.Utils.Application.csproj" />
  </ItemGroup>
</Project>
