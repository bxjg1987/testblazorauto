{
  "name": "zlj-admin-uniapp",
  "version": "1.0.0",
  "description": "ZLJ Admin UniApp - 支持H5、Android、iOS和微信小程序",
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni --open mp-weixin",
    "dev:app-android": "uni --open app-android",
    "dev:app-ios": "uni --open app-ios",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build --open mp-weixin",
    "build:app-android": "uni build --open app-android",
    "build:app-ios": "uni build --open app-ios",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-app-plus": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-h5": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-mp-weixin": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-ui": "^1.5.11",
    "@uni-helper/uni-network": "^0.23.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-i18n": "^9.10.2"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-cli-shared": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/vite-plugin-uni": "^3.0.0-alpha-5000020260104004",
    "@vue/tsconfig": "^0.5.1",
    "sass": "^1.97.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vue-tsc": "^2.0.11"
  }
}
