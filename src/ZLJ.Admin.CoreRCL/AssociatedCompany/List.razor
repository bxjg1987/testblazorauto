@{
    RenderFragment renderFragment =@<Template>
        <SectionOutlet SectionName=@(this.GetHashCode() + "-create-btns") />
        <Button OnClick="CloseCreateDialog">关闭</Button>
    </Template>;
}
<Modal DestroyOnClose="true"   Footer="renderFragment" @bind-Visible="isCreateDialogVisible" 
Draggable="true" Class="frm-dal" 
        Width=@("40vw")
AfterClose="OnAfterCloseDialog">
    <TitleTemplate>
        <Icon Type="plus" Theme="IconThemeType.Outline" />
        新增@(FuncName)
    </TitleTemplate>

    <ChildContent>
        <SectionOutlet SectionName=@(this.GetHashCode() + "-create-body") />
        <Create OnAddEnd="OnAddEnd" Master="this.GetHashCode()"  />
    </ChildContent>
</Modal>

@{
    RenderFragment renderFragment1 =@<Template>
        <SectionOutlet SectionName=@(this.GetHashCode() + "-detail-update-btns") />
        <Button OnClick="CloseUpdateOrDetail">关闭</Button>
    </Template>;
}
<Modal DestroyOnClose="true"
       @bind-Visible="isShowDetailUpdate"
       Draggable="true"
       Title="客户详情"
       Width=@("40vw") 
       Class="frm-dal"
       Maximizable
       AfterClose="OnAfterCloseDialog"
       Footer="renderFragment1"
       DefaultMaximized=false>
    @*<TitleTemplate>
    <SectionOutlet SectionName=@(FuncName + "-detail-update-title") />
    </TitleTemplate> *@
    <ChildContent>
        <SectionOutlet SectionName=@(this.GetHashCode() + "-detail-update-body") />
        <DetailUpdate Id=@detailUpdateId IsEdit=isEdit OnDeleted=OnDetailUpdate OnUpdated=OnDetailUpdate Master="this.GetHashCode()" />
    </ChildContent>
</Modal>