@page "/related-company"

@using ZLJ.Application.Share.AssociatedCompany

@using System.Reflection;
@attribute [ReuseTabsPage(Title = "客户档案")]
@attribute [Authorize(PermissionNames.BXJGBaseInfoAssociatedCompany)]

@inherits ZLJ.RCL.Components.ListBaseComponent<AssociatedCompanyDto, long, PagedAndSortedResultRequest<AssociatedCompanyCondition>>

@* <PageTitle>@pageSuffix</PageTitle> *@
