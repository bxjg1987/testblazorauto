<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>	<GenerateDocumentationFile>True</GenerateDocumentationFile>
	  
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Abps\LocalizationSource.cs" />
    <Compile Remove="Components\AbpCreateDialog.razor.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="Components\AbpCreateDialog.razor" />
    <Content Remove="Components\AbpTreeSelect.razor" />
    <Content Remove="Components\ZljDialog.razor" />
  </ItemGroup>


  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>

		<PackageReference Include="AntDesign" Version="0.17.*" />


		<PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="8.0.1" />
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.1" />
		<!--当前项目定义了拦截器，就算当前项目引用的其它项目已经引用rougamo，这里也必须引用，
	IncludeAssets="all" PrivateAssets="contentfiles;analyzers"是确保拦截器使用方不用引用rougamo的包-->
		<PackageReference Include="Rougamo.Fody" Version="2.1.1" IncludeAssets="all" PrivateAssets="contentfiles;analyzers" />
	</ItemGroup>

	<ItemGroup Condition="'$(SolutionName)' != 'ZLJWithModules'">
		<PackageReference Include="BXJG.Common.RCL" Version="*" />
	</ItemGroup>
	<ItemGroup Condition="'$(SolutionName)' == 'ZLJWithModules'">
		<ProjectReference Include="..\Libs\BXJG.Common.RCL\BXJG.Common.RCL.csproj" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\ZLJ.Application.Common.ClientProxy\ZLJ.Application.Common.ClientProxy.csproj" />
		<ProjectReference Include="..\ZLJ.Application.Share\ZLJ.Application.Share.csproj" />
	</ItemGroup>
</Project>
