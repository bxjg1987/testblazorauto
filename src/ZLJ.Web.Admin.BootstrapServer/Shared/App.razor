@implements IDisposable

@* 能从ioc容器拿的，就别通过级联传递，免得混乱 *@
<CascadingValue Value="context">
    <CascadingAuthenticationState>
        <BootstrapBlazorRoot OnErrorHandleAsync="OnErrorHandleAsync">
            <Router AppAssembly="@typeof(App).Assembly">
                <Found Context="routeData">

                    @* bootstrapblazor中，多标签模式时，此方式无效，它提供了在 layout中去处理的方式 *@
                    @* <AuthorizeRouteView RouteData="@routeData" DefaultLayout="typeof(ZLJ.Web.Admin.BootstrapServer.Shared.AdminMainLayout)">
                        <NotAuthorized>
                            权限验证失败！
                            <AuthenticationRedirectory LoginPath="/account/login?appKey=admin" />
                        </NotAuthorized>
                        <Authorizing>
                            正在验证权限...
                        </Authorizing>
                    </AuthorizeRouteView> *@

                    <PageTitle>Title</PageTitle>
                    <RouteView RouteData="@routeData" DefaultLayout="@typeof(ZLJ.Web.Admin.BootstrapServer.Shared.AdminMainLayout)" />
                  @*   <BootstrapBlazorAuthorizeView RouteData="@routeData" DefaultLayout="@typeof(ZLJ.Web.Admin.BootstrapServer.Shared.AdminMainLayout)">
                         </BootstrapBlazorAuthorizeView> *@
                    <FocusOnNavigate RouteData="@routeData" Selector="h1" />

                </Found>
                <NotFound>
                    <PageTitle>未找到页面</PageTitle>
                    <LayoutView Layout="@typeof(ZLJ.Web.Admin.BootstrapServer.Shared.AdminMainLayout)">
                        <p role="alert">抱歉！没有找到页面，请联系系统管理员。</p>
                    </LayoutView>
                </NotFound>
            </Router>
        </BootstrapBlazorRoot>
    </CascadingAuthenticationState>
    </CascadingValue>
