@*对客户的用量统计后台管理可能也用的着，所以本应该封装到Web.Core项目中，并且按小组件的方式开发
但现在敢进度，现在直接全部写在这个页面里吧*@
@page "/cust"
@inherits OwningComponentBase
@attribute [Authorize(PermissionNames.Customer)]
@inject NavigationManager Navigation
<MudStack>
    <MudStack Row  Justify="@Justify.Center" Spacing="7" >
        <MudChipSet @bind-SelectedChip="selected" Mandatory Filter SelectedChipsChanged="@Shuaxin">
            <MudChip Default="true" Text="dept" Variant="Variant.Outlined" SelectedColor="Color.Primary">按部门</MudChip>
            <MudChip Text="dev" Variant="Variant.Outlined" SelectedColor="Color.Primary">按设备</MudChip>
        </MudChipSet>
        <MudChipSet @bind-SelectedChip="yf" Mandatory Filter SelectedChipsChanged="@Shuaxin">
            <MudChip Default="true" Text="本月" Variant="Variant.Outlined" SelectedColor="Color.Primary">本月</MudChip>
            <MudChip Text="上月" Variant="Variant.Outlined" SelectedColor="Color.Primary">上月</MudChip>
        </MudChipSet>
    </MudStack>
    <MudGrid>
        @if (bumenTonji)
        {
            <MudItem xs="12" md="9">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">部门印量排行</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <BXJGBlazorECharts @ref="bumenTubiao" style="height:360px;" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">部门印量占比</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <BXJGBlazorECharts @ref="bumenTubiaoBing" style="height:360px;" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">数据</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton OnClick="daochuExcel" StartIcon="@Icons.Custom.FileFormats.FileExcel" Variant="Variant.Outlined" Color="Color.Primary">导出excel</MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
        else
        {
            <MudItem xs="12" sm="9">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">设备印量排行</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <BXJGBlazorECharts @ref="shebeiTubiao" style="height:360px;" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">设备印量占比</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <BXJGBlazorECharts @ref="shebeiTubiaoBing" style="height:360px;" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">数据</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton OnClick="daochuExcel" StartIcon="@Icons.Custom.FileFormats.FileExcel" Variant="Variant.Outlined" Color="Color.Primary">导出excel</MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                       
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }


    </MudGrid>
</MudStack>
