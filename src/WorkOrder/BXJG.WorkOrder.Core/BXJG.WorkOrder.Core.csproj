<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <RootNamespace>BXJG.WorkOrder</RootNamespace>
    <Version>1.2.8</Version>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <LangVersion>default</LangVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <LangVersion>default</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="DefaultClsManager.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Localization\SourceFiles\BXJGWorkOrder-en.xml" />
    <None Remove="Localization\SourceFiles\BXJGWorkOrder-zh-Hans.xml" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Localization\SourceFiles\BXJGWorkOrder-en.xml" />
    <EmbeddedResource Include="Localization\SourceFiles\BXJGWorkOrder-zh-Hans.xml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Abp" Version="7.1.0" />
    <PackageReference Include="Yitter.IdGenerator" Version="*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Modules\BXJG.GeneralTree\BXJG.GeneralTree.csproj" />
    <ProjectReference Include="..\..\Modules\BXJG.Utils\BXJG.Utils.csproj" />
  </ItemGroup>

</Project>
