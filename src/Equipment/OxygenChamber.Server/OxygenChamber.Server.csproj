<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net5.0</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <Optimize>false</Optimize>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Protocol\**" />
    <EmbeddedResource Remove="Protocol\**" />
    <None Remove="Protocol\**" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Class3.cs" />
    <Compile Remove="Class4.cs" />
    <Compile Remove="Command\ChangePressureResult.cs" />
    <Compile Remove="Command\OpenCloseDoorResult.cs" />
    <Compile Remove="Command\OpenCloseElectricResult.cs" />
    <Compile Remove="Command\OpenCloseStateResult.cs" />
    <Compile Remove="Command\OpenCloseValveResult.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="appsettings.json" />
    <None Remove="appsettings.Staging.json" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
    <Content Include="appsettings.Staging.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="2.1.1" />
    <PackageReference Include="SuperSocket" Version="2.0.0-beta6" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BXJG.Equipment.Share\BXJG.Equipment.Share.csproj" />
  </ItemGroup>

</Project>
