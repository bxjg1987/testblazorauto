</head>
<body>
    <app>
        <CascadingValue Value="context">
            <CascadingAuthenticationState>
                <AuthenticationRedirectory LoginPath="/account/login" />

                <BlazorRoute @rendermode=" RenderMode.InteractiveServer" />
            </CascadingAuthenticationState>
        </CascadingValue>
        <AntContainer />
    </app>


