<Project Sdk="Microsoft.NET.Sdk.Web">
	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<!--<AssetTargetFallback>$(AssetTargetFallback);portable-net45+win8+wp8+wpa81;</AssetTargetFallback>-->
		<!--<PreserveCompilationContext>true</PreserveCompilationContext>-->
		<AssemblyName>ZLJ.Web.Host</AssemblyName>
		<OutputType>Exe</OutputType>
		<PackageId>ZLJ.Web.Host</PackageId>
		<UserSecretsId>5312EF2F-ABD6-4EFC-AAF2-2E81C34E8FB1</UserSecretsId>
		<!--<AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
		<GenerateBindingRedirectsOutputType>true</GenerateBindingRedirectsOutputType>-->
		<!--<UserSecretsId>bd70b512-f3cf-47e1-8224-da97d4e57dda</UserSecretsId>-->
		<!--企业服务器gc模式-->
		<!--<ServerGarbageCollection>true</ServerGarbageCollection>
		<GarbageCollectionAdaptationMode>true</GarbageCollectionAdaptationMode>-->
		<!--<EnableDefaultContentItems>true</EnableDefaultContentItems>-->
	</PropertyGroup>


	<!--新增的razor组件会因为codegenerate导致无法在将类生产到当前项目，从而导致无法注册blazor路由，下面的设置是暂时性的
		参考：https://github.com/dotnet/aspnetcore/issues/36535# 
	<PropertyGroup>
		<UseRazorSourceGenerator>false</UseRazorSourceGenerator>
	</PropertyGroup>-->


