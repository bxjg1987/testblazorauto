@using AntDesign
@using ZLJ.Admin.CoreRCL.Share
<!DOCTYPE html>
<html lang="zh-cn">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["ZLJ.Web.BlazorAuto.styles.css"]" />
    <script>
        window.serverRootAddress = '@(Cfg?["App:ServerRootAddress"]?.TrimEnd('/') ?? string.Empty)';
        window.environmentName = '@(Env?.EnvironmentName)';
        window.isDevelopment = environmentName == 'Development';
    </script>
    @* 下面这个引用不了，也没必要 *@
    @* <link href="_content/ZLJ.Admin.CoreRCL/css/site.css" rel="stylesheet"> *@
    <ImportMap />
    <HeadOutlet @rendermode="RenderModeForPage" />
</head>

<body style="background: #ddd url('/light-poly.png') repeat;">

    @if (this.RenderModeForPage != null)
    {
        <div id="loadingDiv" style="display:none; background-color:#eee; position:absolute;z-index:9999; width:100%; height:100%; text-align:center; padding-top:30vh ">
            <Spin Tip="加载中，请稍后..." Size="SpinSize.Large" />
        </div>
    }
    <script>
        try { document.getElementById('loadingDiv').style.display = 'block'; } catch { }
        function hideLoadingDiv() {
            //removeClass(document.getElementById('loadingDiv'), 'show-loading');
            try {
                document.getElementById('loadingDiv').style.display = 'none';
            } catch { }
        }

    </script>




    <app>
        <Routes @rendermode="RenderModeForPage" />
    </app>
    @* 图表库，cdn经常访问不了 *@
    @* <script type="text/javascript" src="@("https://unpkg.com/@antv/g2plot@2.4.17/dist/g2plot.min.js")"></script> *@
    @* <script type="text/javascript" src="g2plot.min.js"></script> *@
    @* 新版本已经内嵌了 *@
    @* <script src="_content/AntDesign/js/ant-design-blazor.js"></script> *@
    @* <script src="_content/AntDesign.Charts/ant-design-charts-blazor.js"></script> *@
   

    <script>
        // WASM缓存有效期验证：若缓存可能已被浏览器LRU淘汰，则删除localStorage标记，让Blazor回退到Server模式
        (function () {
            const wasmAssemblyName = 'ZLJ.Admin.CoreRCL';
            const resourceHashKey = 'blazor-resource-hash:' + wasmAssemblyName;
            const cacheTimestampKey = 'blazor-cache-timestamp:' + wasmAssemblyName;
            const maxAgeMs = 12 * 60 * 60 * 1000; // 12小时，可根据实际情况调整
            if (localStorage.getItem(resourceHashKey)) {
                const ts = localStorage.getItem(cacheTimestampKey);
                if (!ts || Date.now() - parseInt(ts) > maxAgeMs) {
                    localStorage.removeItem(resourceHashKey);
                    localStorage.removeItem(cacheTimestampKey);
                }
            }
        })();
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["app.js"]"></script>
  
    <Microsoft.AspNetCore.Components.Sections.SectionOutlet SectionName="bottom-scripts" />
</body>
</html>