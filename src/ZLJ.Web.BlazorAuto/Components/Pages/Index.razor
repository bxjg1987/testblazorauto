@page "/"
@using BXJG.Common.RCL

@layout PublicLayout

<PageTitle>xxx管理系统</PageTitle>

        <!-- 产品介绍区域 -->
        <section class="hero-section">
            <div class="hero-content">
                <div class="hero-text-content">
                    <h1 class="hero-title">xxxx</h1>
                    <p class="hero-subtitle">xxxxxx</p>
                    <div class="hero-buttons">
                @if (!IsAuthenticated)
                {
                    <a href="/regtenant" class="btn-primary" data-enhance-nav="false">立即注册</a>
                    <a href="/main" class="btn-secondary" data-enhance-nav="false">已有账号？立即登录</a>
                }
                else
                {
                    <a href="/main" class="btn-primary" data-enhance-nav="false">进入后台管理端</a>
                }
                    </div>
                </div>
                <div class="hero-image-content">
                    <img src="images/cpjs.png" alt="产品展示" class="product-image" />
                </div>
            </div>
        </section>
        <!-- 功能特性区域 -->
        <section class="features-section" id="features">
            <div class="container">
                <h2 class="section-title">核心功能</h2>
                <div class="features-grid">
                    <div class="feature-card core-feature">
                        <div class="feature-icon">🚀</div>
                        <h3 class="feature-title">功能1</h3>
                        <p class="feature-description">
                            xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
                        </p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">⚠️</div>
                        <h3 class="feature-title">功能2</h3>
                        <p class="feature-description">
                            实xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
                        </p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">👥</div>
                        <h3 class="feature-title">功能3</h3>
                        <p class="feature-description">
                            xxxxxxxxxxxxxxxxxxxxxxxx
                        </p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">📋</div>
                        <h3 class="feature-title">功能4</h3>
                        <p class="feature-description">
                            xxxxxxxxxxxxxxxxxxxxxxxx
                        </p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">📊</div>
                        <h3 class="feature-title">功能5</h3>
                        <p class="feature-description">
                            嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻嘻
                        </p>
                    </div>
                    <div class="feature-card simple-feature">
                        <div class="feature-icon">🔧</div>
                        <h3 class="feature-title">持续开发中</h3>
                        <p class="feature-description">
                            更多实用功能正在紧锣密鼓地开发中，为您提供更完善的租赁管理体验
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 价格方案区域 -->
        <section class="pricing-section" id="pricing">
            <div class="container">
                <h2 class="section-title">价格方案</h2>
                <div class="pricing-grid">
                    <div class="pricing-card">
                        <h3 class="plan-name">方案A</h3>
                        <p class="plan-description">价格更实惠</p>
                        <div class="plan-price">¥2<span class="price-unit">/台/年</span></div>
                        <ul class="plan-features">
                            <li>aaaaa</li>
                            <li>bbbbbbbbbbbbbbbbb</li>
                            <li>cccccccccccccccccc</li>
                            @*<li>设备状态监控</li>
                            <li>报表导出功能</li> *@
                        </ul>
                    </div>
                    <div class="pricing-card featured">
                        <h3 class="plan-name">方案B</h3>
                        <p class="plan-description">功能更强大</p>
                        <div class="plan-price">¥5<span class="price-unit">/台/年</span></div>
                        <ul class="plan-features">
                            <li>aaaaaaa</li>
                            <li>bbbbbbbbbbbbb</li>
                            <li>cccccccccccc</li>
                            <li>ddddddddd</li>
                            <li>eeeeeeeeeeeeeeeeeeeee</li>
                        </ul>
                    </div>
                </div>
                <div class="tip" style="color:black;">
                    <strong>💡灵活选择：</strong>
                    支持部分设备使用按天采集，部分设备使用网关采集；
                    或同一台设备同时支持网关采集，失效时回退到按天采集，此时仅按网关采集方式收费。
                </div>
                <div class="free-notice">
                    <h3>🎉 限时优惠</h3>
                    <p><strong>目前处于测试阶段，完全免费使用！</strong></p>
                    <p>测试期间的数据会完整保留，正式使用时无需重新建立档案，可直接切换至付费版本</p>
                  
                   @*  <p class="flexibility-note">
                        <em>灵活选择：支持部分设备使用按天采集，部分设备使用网关采集；<br />
                            或同一台设备同时支持网关采集，失效时回退到按天采集，此时仅按网关采集方式收费。</em>
                    </p> *@
                </div>
            </div>
        </section>

     