<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <Nullable>enable</Nullable>
	  <GenerateDocumentationFile>true</GenerateDocumentationFile>
	  <ImplicitUsings>enable</ImplicitUsings>
	  <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Notify\NotifyListBase.cs" />
    <Compile Remove="Notify\NotifySubscriptBase.cs" />
  </ItemGroup>


  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>


	<ItemGroup Condition="'$(SolutionName)' != 'ZLJWithModules'">
		<PackageReference Include="BXJG.MudBlazor" Version="*" />
	</ItemGroup>
	<ItemGroup Condition="'$(SolutionName)' == 'ZLJWithModules'">
		<ProjectReference Include="..\Modules\BXJG.MudBlazor\BXJG.MudBlazor.csproj" />
	</ItemGroup>
	
	<ItemGroup>
		<PackageReference Include="Abp.AspNetCore" Version="8.3.1" />
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="7.0.10" />
		<PackageReference Include="MudBlazor" Version="6.8.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\ZLJ.Application\ZLJ.Application.csproj" />
		<ProjectReference Include="..\ZLJ.Web.Core\ZLJ.Web.Core.csproj" />
	</ItemGroup>

</Project>
